{
	"name": "pdf-extract",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"engineStrict": true,
	"engines": {
		"node": "^24",
		"pnpm": ">=10.28"
	},
	"scripts": {
		"preinstall": "npx only-allow pnpm",
		"dev": "vite",
		"typecheck": "tsc -b --noEmit",
		"build": "tsc -b && vite build",
		"fix": "biome check --write --diagnostic-level=info",
		"fix:unsafe": "biome check --write --unsafe --verbose",
		"prepare": "husky"
	},
	"lint-staged": {
		"*": "biome check --write --no-errors-on-unmatched --error-on-warnings"
	},
	"dependencies": {
		"@heroui/react": "^3.0.3",
		"@heroui/styles": "^3.0.3",
		"@tailwindcss/vite": "^4.2.4",
		"pdf-lib": "^1.17.1",
		"pdfjs-dist": "^5.6.205",
		"react": "^19.2.5",
		"react-dom": "^19.2.5",
		"tailwindcss": "^4.2.4"
	},
	"devDependencies": {
		"@babel/core": "^7.29.0",
		"@biomejs/biome": "2.4.12",
		"@eslint/js": "^9.39.4",
		"@rolldown/plugin-babel": "^0.2.3",
		"@types/babel__core": "^7.20.5",
		"@types/node": "^24.12.2",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.1",
		"babel-plugin-react-compiler": "^1.0.0",
		"globals": "^17.5.0",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0",
		"typescript": "~6.0.3",
		"vite": "^8.0.9"
	}
}
